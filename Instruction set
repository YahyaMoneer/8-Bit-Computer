0000 LDA (load register A)
0001 STA (store register A)
0010 MAB (copy register A to register B)
0011 DMA (direct memory access)
0100 JMP (unconditional jump)
0101 JN  (jump if negative)
0110 JZ  (jump if zero)
0111 JC  (jump if carry)
1000 ADD (register A + register B = register A)
1001 SUB (register A - register B = register A)
1010 XOR (register A XOR register B = register A)
1011 AND (register A AND register B = register A)
1100 NOT (register A = !register A)
1101 SHR (shift right register A)
1110 HLT (halt system clock)
1111 NOP (no operation)
